// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Project {
  id             String   @id @default(cuid())
  title          String
  slug           String   @unique
  subtitle       String   @default("")
  description    String
  overview       String   @default("")
  category       String
  context        String   @default("")
  problem        String   @default("")
  goals          String[]
  approach       String   @default("")
  solution       String   @default("")
  businessImpact String   @default("")
  metrics        String[]
  timeline       String   @default("")
  role           String   @default("")
  team           String[]
  deliverables   String[]
  tools          String[]
  images         String[]
  documents      String[]
  featured       Boolean  @default(false)
  published      Boolean  @default(true)
  sortOrder      Int      @default(0)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model Hero {
  id          String       @id @default(cuid())
  badge       String
  name        String
  headline    String
  description String
  pillars     HeroPillar[]
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
}

model HeroPillar {
  id        String @id @default(cuid())
  heroId    String
  hero      Hero   @relation(fields: [heroId], references: [id], onDelete: Cascade)
  label     String
  title     String
  text      String
  sortOrder Int    @default(0)
}

model About {
  id          String   @id @default(cuid())
  title       String
  paragraph1  String
  paragraph2  String
  highlights  String[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Experience {
  id           String   @id @default(cuid())
  title        String
  company      String
  date         String
  achievements String[]
  sortOrder    Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Contact {
  id          String              @id @default(cuid())
  heading     String
  description String
  email       String
  copyright   String
  socialLinks ContactSocialLink[]
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt
}

model ContactSocialLink {
  id        String  @id @default(cuid())
  contactId String
  contact   Contact @relation(fields: [contactId], references: [id], onDelete: Cascade)
  label     String
  href      String
  sortOrder Int     @default(0)
}
